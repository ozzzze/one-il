{
	"name": "one-il",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp",
			"esbuild"
		]
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"supabase:start": "npx supabase start",
		"supabase:stop": "npx supabase stop",
		"db:apply:migration": "node --env-file=.env scripts/apply-migration-pg.mjs",
		"db:types": "node --env-file=.env scripts/gen-db-types.mjs",
		"notifications:process": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/process-notification-outbox.ts",
		"check:notifications": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/check-notification-setup.ts",
		"db:apply:outbox": "node --env-file=.env scripts/apply-outbox-migration-pg.mjs",
		"db:apply:user-change-requests": "node --env-file=.env scripts/apply-migration-pg.mjs supabase/migrations/20260601130000_user_change_requests_one_leave.sql",
		"db:seed:menu-catalog": "node --env-file=.env scripts/apply-migration-pg.mjs supabase/migrations/20260601140000_gateway_menu_catalog_seed.sql",
		"db:apply:user-admin-audit": "node --env-file=.env scripts/apply-migration-pg.mjs supabase/migrations/20260602120000_one_leave_user_admin_audit.sql",
		"db:seed:admin-menu": "node --env-file=.env scripts/apply-migration-pg.mjs supabase/migrations/20260602130000_gateway_admin_menu_seed.sql",
		"test:email": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/test-email-notification.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bcryptjs": "^3.0.0",
		"@types/d3-array": "^3.2.2",
		"@types/d3-scale": "^4.0.9",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"bits-ui": "^2.16.3",
		"d3-array": "^3.2.4",
		"d3-scale": "^4.0.2",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"pg": "^8.20.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.1.1",
		"sharp": "^0.34.5",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"svelte-meta-tags": "^4.5.0",
		"svelte-sonner": "^1.0.8",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@oslojs/encoding": "^1.1.0",
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.105.1",
		"arctic": "^3.7.0",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"nodemailer": "^8.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3"
	}
}
