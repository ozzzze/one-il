# Postgres connection string — Supabase local CLI หรือ Supabase Cloud
# Local: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Cloud: ใส่รหัสจาก Dashboard > Project Settings > Database (แทน YOUR_DB_PASSWORD)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.kcmcqadqsbrhuzekxxlp.supabase.co:5432/postgres?sslmode=require

# URL ที่ผู้ใช้เปิดแอป (สำหรับลิงก์ redirect ของ Supabase Auth)
ORIGIN=http://localhost:5173

# Supabase — Project URL + Publishable key (Dashboard > API)
PUBLIC_SUPABASE_URL=https://kcmcqadqsbrhuzekxxlp.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — Dashboard > API > service_role (ห้าม commit ลง git)
SUPABASE_SERVICE_ROLE_KEY=

# Outbound email (Gmail interim — App Password จาก Google Account > Security)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=il.websystem@gmail.com
SMTP_PASS=
SMTP_FROM=ONE-IL <il.websystem@gmail.com>
