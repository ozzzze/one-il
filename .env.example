# Database
DATABASE_URL=svelteforge.db

# Application URL (used for OAuth redirect URIs)
ORIGIN=http://localhost:5173

# OAuth Providers (all optional — omit to disable social login)

# Google OAuth 2.0
# Create at: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: {ORIGIN}/login/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Set callback URL to: {ORIGIN}/login/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
