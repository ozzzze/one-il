# Postgres — พอร์ต 54322 (ไม่ใช่ 54323 Studio)
# ตัวอย่าง intranet: postgresql://postgres:YOUR_PASSWORD@10.21.1.103:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# URL ที่ผู้ใช้เปิดแอป (สำหรับลิงก์ redirect ของ Supabase Auth)
ORIGIN=http://localhost:5173

# Supabase API — พอร์ต 54321 (ไม่ใช่ 54323 Studio)
# ตัวอย่าง intranet: http://10.21.1.103:54321
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# OAuth legacy (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
