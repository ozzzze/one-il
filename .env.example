# --- Runtime (required) — self-hosted VPS หรือ Supabase Cloud ---
# VPS (ONE-IL production): API ที่พอร์ต 8000 — แอปไม่ต้องใช้ DATABASE_URL
PUBLIC_SUPABASE_URL=http://187.77.137.14:8000
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Ops only (migrations / pnpm db:apply:outbox) — ไม่ commit รหัสจริง ---
# วิธีสั้น: ใส่รหัส Postgres ของ VPS แล้วรัน pnpm db:apply:outbox
# POOLER_TENANT_ID=your-tenant-id
# SELF_HOSTED_DB_PASSWORD=POSTGRES_PASSWORD จาก VPS docker .env (ไม่ใช่รหัส Cloud)
# หรือ connection string (รหัสมี * @ ต้อง encode เช่น * → %2A):
# SELF_HOSTED_DATABASE_URL=postgresql://postgres.your-tenant-id:YOUR_PASSWORD@187.77.137.14:5432/postgres

# Supabase Cloud (ถ้าใช้ cloud แยก — ไม่ใช่ VPS runtime)
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.kcmcqadqsbrhuzekxxlp.supabase.co:5432/postgres?sslmode=require

# URL ที่ผู้ใช้เปิดแอป (ลิงก์ในอีเมลแจ้งเตือน)
ORIGIN=http://localhost:5173

# Server-only — Dashboard > API > service_role (ห้าม commit ลง git)
SUPABASE_SERVICE_ROLE_KEY=

# Outbound email (Gmail interim — App Password จาก Google Account > Security)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=il.websystem@gmail.com
SMTP_PASS=
SMTP_FROM=ONE-IL <il.websystem@gmail.com>
# SMTP_REPLY_TO=

# OAuth legacy (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
