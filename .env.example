# ONE TEMPLATE (team standard)
# 1) copy this file -> .env
# 2) fill values marked <...>
# 3) choose ONE DB mode below:
#    - MODE A: SSH TUNNEL (recommended for local dev outside VPS)
#    - MODE B: DIRECT POOLER (when network route to VPS pooler is stable)
#
# -------------------------------------------------------------------
# Local dev ports
# -------------------------------------------------------------------
LEAVE_DEV_PORT=5174
# Proxy target uses http://localhost (not 127.0.0.1) — see vite.config.ts
# VITE_PORT=5173

# -------------------------------------------------------------------
# Auth mode
# -------------------------------------------------------------------
# MOCK for development without real DB auth:
AUTH_MOCK=true
AUTH_MOCK_PASSWORD=Demo@2569
# When testing real auth, set AUTH_MOCK=false

# Session secret (MUST match one-leave/.env in same environment)
# Generate: openssl rand -base64 48
SESSION_SECRET=<SET_SHARED_SESSION_SECRET>

# -------------------------------------------------------------------
# one_leave Postgres auth source (required for real login / admin pages)
# -------------------------------------------------------------------
# Must come from VPS supabase/docker/.env
POOLER_TENANT_ID=<SET_POOLER_TENANT_ID> # e.g. srv1663763
SELF_HOSTED_DB_PASSWORD=<SET_POSTGRES_PASSWORD>

# MODE A: SSH TUNNEL (recommended)
# - keep tunnel open:
#   ssh -L 6543:127.0.0.1:6543 <user>@<vps-host>
# - then use:
# PG_HOST=127.0.0.1
# PG_PORT=6543
# DATABASE_URL=postgresql://postgres@127.0.0.1:6543/postgres

# MODE B: DIRECT POOLER (requires stable network route from local machine)
PG_HOST=<SET_VPS_HOST>   # e.g. 187.77.137.14
PG_PORT=6543
DATABASE_URL=postgresql://postgres@<SET_VPS_HOST>:6543/postgres

# Optional explicit override (normally leave empty; user is auto-built as postgres.<tenant>)
# PG_USER=postgres

# -------------------------------------------------------------------
# Optional Supabase API (legacy routes / menu catalog admin)
# -------------------------------------------------------------------
PUBLIC_SUPABASE_URL=http://<SET_VPS_HOST>:8000
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# or alias: PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------------------------------
# Ops only (migrations / pnpm db:apply:*) — do not commit real secrets
# -------------------------------------------------------------------
# วิธีสั้น: ใส่รหัส Postgres ของ VPS แล้วรัน pnpm db:apply:outbox
# POOLER_TENANT_ID=your-tenant-id
# SELF_HOSTED_DB_PASSWORD=POSTGRES_PASSWORD จาก VPS docker .env (ไม่ใช่รหัส Cloud)
# หรือ connection string (รหัสมี * @ ต้อง encode เช่น * → %2A):
# SELF_HOSTED_DATABASE_URL=postgresql://postgres.your-tenant-id:YOUR_PASSWORD@187.77.137.14:5432/postgres

# -------------------------------------------------------------------
# App URL / public runtime
# -------------------------------------------------------------------
# URL ที่ผู้ใช้เปิดแอป (ลิงก์ในอีเมลแจ้งเตือน)
ORIGIN=http://localhost:5173

# SCR attachments (FR-09) — shared with one-leave legacy paths; set UNC in production
# CHANGE_UPLOAD_DIR=uploads/change-request

# -------------------------------------------------------------------
# Server-only secrets
# -------------------------------------------------------------------
# Dashboard > API > service_role (ห้าม commit ลง git)
SUPABASE_SERVICE_ROLE_KEY=

# Outbound email (Gmail interim — App Password จาก Google Account > Security)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=il.websystem@gmail.com
SMTP_PASS=
SMTP_FROM=ONE-IL <il.websystem@gmail.com>
# SMTP_REPLY_TO=

# OAuth legacy (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
